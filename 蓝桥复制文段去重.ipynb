   "source": [
    "#处理文段中字体重复\n",
    "\n",
    "err = input().replace(' ','')\n",
    "\n",
    "tru = []\n",
    "\n",
    "for j in range(len(err)):\n",
    "    try:\n",
    "        if err[j] != err[j + 1]:\n",
    "            tru.append(err[j])\n",
    "    except:\n",
    "        tru.append(err[j])\n",
    "\n",
    "print()\n",
    "print(''.join(tru))"
   ]
  }
 ],
